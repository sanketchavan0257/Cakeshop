{
  "rewrites": [
    { "source": "/admin/orders", "destination": "/admin-orders.html" },
    { "source": "/admin/users", "destination": "/admin-users.html" },
    { "source": "/admin/cakes", "destination": "/admin-cakes.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
